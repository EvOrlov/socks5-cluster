# ================================
# SOCKS5 Cluster Configuration
# ================================

# Number of Docker containers
CONTAINER_COUNT=12

# Number of proxies inside each container
PROXIES_PER_CONTAINER=250


# ================================
# Network configuration
# ================================

# Starting port for proxy allocation
START_PORT=1080

# Services used to detect public IP
# Multiple services can be separated by comma
VERIFY_SERVICES=https://api.ipify.org,https://ifconfig.me/ip


# ================================
# Proxy credentials
# ================================

# Username prefix
USERNAME_PREFIX=user

# Password length
PASSWORD_LENGTH=8


# ================================
# Docker container limits
# ================================

# Memory limit per container
CONTAINER_MEMORY=30m

# CPU limit per container
CONTAINER_CPU=0.15


# ================================
# Timing configuration
# ================================

# Delay between container launches (seconds)
STARTUP_DELAY=15

# Time to wait before verification starts (seconds)
INITIALIZATION_TIME=60