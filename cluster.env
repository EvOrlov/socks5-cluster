# Cluster configuration
CONTAINER_COUNT=1
PROXIES_PER_CONTAINER=10

# Ports
START_PORT=1080

# Proxy credentials
USERNAME_PREFIX=user
PASSWORD_LENGTH=8

# Resource limits
CONTAINER_MEMORY=30m
CONTAINER_CPU=0.15

# Verification services
VERIFY_SERVICES=https://api.ipify.org,https://ifconfig.me/ip

# Timing
STARTUP_DELAY=5
HEALTH_CHECK_DELAY=20