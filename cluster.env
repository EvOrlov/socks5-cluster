# ===============================
# SOCKS5 Cluster Configuration
# ===============================

# ---- Cluster Scale ----
# Total proxies = CONTAINER_COUNT * PROXIES_PER_CONTAINER

CONTAINER_COUNT=12
PROXIES_PER_CONTAINER=250

BASE_PORT=1080


# ---- Per-Container Resource Limits ----
# Designed to run even on 2 vCPU / 2GB RAM VPS

MEMORY_LIMIT=30m
CPU_LIMIT=0.15


# ---- Startup Behavior ----

STARTUP_DELAY=15
INITIALIZATION_TIME=60


# ---- VPS Safety Thresholds ----

MIN_FREE_RAM_MB=300
MAX_CPU_PERCENT=85


# ---- Proxy Verification ----
# Provide one URL per line.
# The number of services = number of proxies tested per container.
# Leave empty to disable verification.

VERIFY_SERVICES=https://api.ipify.org,https://ifconfig.me/ip

VERIFY_TIMEOUT=10